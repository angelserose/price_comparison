# ========================================
# SNAP Price Comparison - Environment Variables
# ========================================
# 
# IMPORTANT: Create a .env file (NOT .env.example) with your actual values
# NEVER commit .env to Git - it's added to .gitignore
#
# ========================================

# Database Configuration
# Get this from Supabase Project Settings → Database → Connection String
# Format: postgresql://postgres:PASSWORD@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Secret Key for Sessions (Generate a strong random key!)
# Use: https://randomkeygen.com/
# Or run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-to-something-random-and-strong

# Server Port (Render will override this to 10000)
PORT=5000

# ========================================
# HOW TO SET UP:
# ========================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. NEVER push .env to GitHub
# 4. Keep .env.example in repository (as reference)
# ========================================
